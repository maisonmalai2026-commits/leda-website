  {
    "id": "wf_study_plan_builder",
    "owner_id": "prof_leo_studies",
    "slug": "study-plan-builder",
    "title": "Study Plan Builder",
    "short_description": "Turn a topic and a deadline into a day-by-day study plan.",
    "long_description": "Give it a subject and a target date and the main brain breaks the work into a realistic day-by-day plan. It checks whether your deadline is tight and adjusts the pace, then saves the plan to your notes.",
    "category_id": "cat_education",
    "tags": ["study", "planning", "education", "notes"],
    "workflow_json": {
      "nodes": [
        {
          "id": "n_trigger",
          "type": "manual_trigger",
          "label": "Start",
          "config": { "input": "subject and deadline" },
          "position": { "x": 0, "y": 0 }
        },
        {
          "id": "n_check",
          "type": "condition",
          "label": "Deadline tight?",
          "config": { "expression": "days_until_deadline < 7" },
          "position": { "x": 220, "y": 0 }
        },
        {
          "id": "n_brain_fast",
          "type": "main_brain",
          "label": "Build intensive plan",
          "config": { "instruction": "Create a compressed study plan." },
          "position": { "x": 440, "y": -80 }
        },
        {
          "id": "n_brain_steady",
          "type": "main_brain",
          "label": "Build steady plan",
          "config": { "instruction": "Create a paced study plan." },
          "position": { "x": 440, "y": 80 }
        },
        {
          "id": "n_save",
          "type": "call_native_plugin",
          "label": "Save to notes",
          "config": { "plugin": "notes-summarizer", "action": "save_note" },
          "position": { "x": 660, "y": 0 }
        },
        {
          "id": "n_end",
          "type": "end",
          "label": "Done",
          "position": { "x": 880, "y": 0 }
        }
      ],
      "edges": [
        { "id": "e1", "source": "n_trigger", "target": "n_check" },
        { "id": "e2", "source": "n_check", "target": "n_brain_fast", "condition": "true" },
        { "id": "e3", "source": "n_check", "target": "n_brain_steady", "condition": "false" },
        { "id": "e4", "source": "n_brain_fast", "target": "n_save" },
