  {
    "id": "wf_verified_whatsapp_message",
    "owner_id": "prof_rin_flows",
    "slug": "verified-whatsapp-message",
    "title": "Verified WhatsApp Message",
    "short_description": "Draft a WhatsApp message, confirm before sending, and verify it was delivered.",
    "long_description": "A safety-first messaging flow. The main brain drafts a WhatsApp message from your prompt, then pauses for an explicit confirmation before anything is sent. After sending through the WhatsApp Agent plugin, it verifies the result and notifies you of the outcome. Nothing is sent without your approval.",
    "category_id": "cat_communication",
    "tags": ["whatsapp", "messaging", "confirmation", "safety"],
    "workflow_json": {
      "nodes": [
        {
          "id": "n_trigger",
          "type": "manual_trigger",
          "label": "Start",
          "config": { "input": "recipient and message intent" },
          "position": { "x": 0, "y": 0 }
        },
        {
          "id": "n_brain",
          "type": "main_brain",
          "label": "Draft message",
          "config": { "instruction": "Draft a concise WhatsApp message for the recipient." },
          "position": { "x": 220, "y": 0 }
        },
        {
          "id": "n_confirm",
          "type": "ask_confirmation",
          "label": "Confirm before sending",
          "config": { "prompt": "Send this WhatsApp message?" },
          "position": { "x": 440, "y": 0 }
        },
        {
          "id": "n_send",
          "type": "call_native_plugin",
          "label": "Send via WhatsApp Agent",
          "config": { "plugin": "whatsapp-agent", "action": "send_message" },
          "position": { "x": 660, "y": 0 }
        },
        {
          "id": "n_verify",
          "type": "verify_result",
          "label": "Verify delivery",
          "config": { "check": "message_delivered" },
          "position": { "x": 880, "y": 0 }
        },
        {
          "id": "n_notify",
          "type": "notify_user",
          "label": "Notify outcome",
          "config": { "channel": "in_app" },
          "position": { "x": 1100, "y": 0 }
        },
        {
          "id": "n_end",
          "type": "end",
          "label": "Done",
          "position": { "x": 1320, "y": 0 }
        }
      ],
      "edges": [
        { "id": "e1", "source": "n_trigger", "target": "n_brain" },
        { "id": "e2", "source": "n_brain", "target": "n_confirm" },
        { "id": "e3", "source": "n_confirm", "target": "n_send", "condition": "approved" },
        { "id": "e4", "source": "n_send", "target": "n_verify" },
        { "id": "e5", "source": "n_verify", "target": "n_notify" },
        { "id": "e6", "source": "n_notify", "target": "n_end" }
      ]
    },
