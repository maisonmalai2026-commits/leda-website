# ----------------------------------------------------------------------------
# Leda website environment variables
# Copy this file to ".env.local" and fill in values as they become available.
# Never commit real secrets. This site does not require any secret keys.
# ----------------------------------------------------------------------------

# Public download URL for the Leda Windows build.
# Leave EMPTY until there is a real release — the download button will then
# read "Windows download coming soon" instead of linking anywhere.
NEXT_PUBLIC_LEDA_WINDOWS_DOWNLOAD_URL=

# Public GitHub URL (repository or org). Used by the navbar/footer links.
NEXT_PUBLIC_LEDA_GITHUB_URL=

# Waitlist storage mode for the demo backend.
#   local = append submissions to data/waitlist.json on the server
#   demo  = accept the submission but do not persist anything
WAITLIST_STORAGE_MODE=local

# ----------------------------------------------------------------------------
# Marketplace (Phase 2)
#
# Leave Supabase + Stripe values EMPTY to run the marketplace in local DEMO
# MODE: it serves seed data, uses a cookie-based demo sign-in, and never calls
# any external service. Fill these in only when you wire up real backends.
# ----------------------------------------------------------------------------

# Public app URL (used for canonical links, Stripe redirects, emails).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (auth, database, storage metadata, RLS) ---
# Public values — safe to expose to the browser (protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY. Never expose to the browser, never import in a client component,
# never commit. Used only by server-only modules for privileged operations.
SUPABASE_SERVICE_ROLE_KEY=SERVER_ONLY_DO_NOT_EXPOSE

# --- Stripe (future-gated payments via Stripe Connect) ---
# Real checkout stays OFF until this is "true" AND keys are configured.
MARKETPLACE_PAYMENTS_ENABLED=false

# Public publishable key — safe to expose.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# SERVER ONLY. Never expose, never commit.
STRIPE_SECRET_KEY=SERVER_ONLY_DO_NOT_EXPOSE
STRIPE_WEBHOOK_SECRET=SERVER_ONLY_DO_NOT_EXPOSE
